# .sqlfluff (Updated for sqlfluff v3.0+)

[sqlfluff]
dialect = duckdb
rules = capitalisation.keywords, capitalisation.functions, layout

# ------------------------------------------------------------------
# Rule-specific configurations with updated names
# ------------------------------------------------------------------

# Keyword capitalization
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

# Function names capitalization
[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper

# Indentation
[sqlfluff:rules:layout.indent]
tab_space_size = 8
indent_unit = space

# Spacing
[sqlfluff:rules:layout.spacing]
spacing_within = single